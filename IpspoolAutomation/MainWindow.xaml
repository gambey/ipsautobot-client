<Window x:Class="IpspoolAutomation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ipspool 自动化" Height="760" Width="1180"
        MinHeight="700" MinWidth="1080"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#FFF5F6F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF1F2937" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="IPS_AUTOBOT" Foreground="White" FontWeight="SemiBold" FontSize="16" Margin="0,0,16,0"/>
                    <TextBlock Text="当前用户:" Foreground="#FFD1D5DB" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding UserInfo}" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="   |   到期时间:" Foreground="#FFD1D5DB" VerticalAlignment="Center" Margin="12,0,6,0"/>
                    <TextBlock Text="{Binding ExpireAtText}" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="   |   " Foreground="#FFD1D5DB" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SubscriptionStatusText}" Foreground="#FFF59E0B" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="退出登录" Command="{Binding LogoutCommand}" Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FF111827" Padding="12">
                <StackPanel>
                    <TextBlock Text="功能菜单" Foreground="#FF9CA3AF" Margin="8,8,8,14"/>
                    <Button Content="提现" Command="{Binding GoWithdrawCommand}" Margin="0,0,0,8" Padding="12,10"/>
                    <Button Content="提现详情" Command="{Binding GoWithdrawDetailCommand}" Margin="0,0,0,8" Padding="12,10"/>
                    <Button Content="提现记录" Command="{Binding GoWithdrawRecordsCommand}" Margin="0,0,0,8" Padding="12,10"/>
                    <Button Content="签到" Command="{Binding GoCheckinCommand}" Margin="0,0,0,8" Padding="12,10"/>
                    <Button Content="设置" Command="{Binding GoSettingsCommand}" Margin="0,0,0,8" Padding="12,10"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="12" Background="White" CornerRadius="8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="18" FontWeight="SemiBold">
                 
                        <Run Text="{Binding CurrentPage}"/>
                    </TextBlock>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid Visibility="{Binding IsWithdrawDetailPage, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock HorizontalAlignment="Right"
                                           Text="{Binding TotalExchangedCoins, StringFormat=合计讯币：{0:F0}}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Grid.Row="1">
                                <TextBlock Text="当前无提现记录"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#FF6B7280"
                                           FontSize="15"
                                           Visibility="{Binding IsWithdrawDetailEmpty, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <Border BorderBrush="#FF707070" BorderThickness="1"
                                        Visibility="{Binding IsWithdrawDetailEmpty, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <DataGrid ItemsSource="{Binding WithdrawDetailItems}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                                          GridLinesVisibility="All" BorderThickness="0" FontSize="14" RowHeight="36">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#FF15A8E9"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Height" Value="36"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="序号" Binding="{Binding RowIndex}" Width="56" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="账号" Binding="{Binding Account}" Width="1.2*"/>
                                        <DataGridTextColumn Header="兑换积分" Binding="{Binding Points}" Width="1*"/>
                                        <DataGridTextColumn Header="剩余积分" Binding="{Binding RemainingPoints}" Width="1*"/>
                                        <DataGridTextColumn Header="已兑讯币" Binding="{Binding ExchangedCoins}" Width="1*"/>
                                        <DataGridTextColumn Header="手续费" Binding="{Binding Fee}" Width="1*"/>
                                        <DataGridTextColumn Header="兑换状态" Binding="{Binding Status}" Width="1*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="#FF374151"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="成功">
                                                            <Setter Property="Foreground" Value="#FF059669"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="失败">
                                                            <Setter Property="Foreground" Value="#FFDC2626"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid Visibility="{Binding IsWithdrawPage, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding WithdrawStatusMessage}" Margin="0,0,0,10" TextWrapping="Wrap"/>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="执行自动提现" Command="{Binding StartWithdrawCommand}" Padding="12,6" Margin="0,0,8,0"/>
                                <Button Content="停止" Command="{Binding StopCommand}" Padding="12,6"/>
                            </StackPanel>
                            <TextBox Grid.Row="2"
                                     Text="{Binding LogText}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     BorderBrush="#FFE5E7EB"
                                     BorderThickness="1"
                                     Padding="8"
                                     MinHeight="220"/>
                        </Grid>

                        <Grid Visibility="{Binding IsWithdrawRecordsPage, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock HorizontalAlignment="Right"
                                           Text="{Binding WithdrawRecordsTotalDisplay}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Border Grid.Row="1" BorderBrush="#FF707070" BorderThickness="1">
                                <DataGrid ItemsSource="{Binding WithdrawRecords}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                                          GridLinesVisibility="All" BorderThickness="0" FontSize="14" RowHeight="36">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#FF15A8E9"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Height" Value="36"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="序号" Binding="{Binding RowIndex}" Width="56" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="时间" Binding="{Binding TimeDisplay}" Width="1.8*"/>
                                        <DataGridTextColumn Header="处理账号数" Binding="{Binding ProcessedAccountCount}" Width="1*"/>
                                        <DataGridTextColumn Header="金额" Binding="{Binding Amount, StringFormat=F0}" Width="1*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>

                        <Grid Visibility="{Binding IsCheckinPage, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="签到方式:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <RadioButton Content="立刻签到" GroupName="CheckinMode" IsChecked="{Binding IsImmediateCheckinMode}" Margin="0,0,36,0" VerticalAlignment="Center"/>
                                <RadioButton Content="定时签到" GroupName="CheckinMode" IsChecked="{Binding IsScheduledCheckinMode}" Margin="0,0,36,0" VerticalAlignment="Center"/>
                                <RadioButton Content="取消签到" GroupName="CheckinMode" IsChecked="{Binding IsCancelCheckinMode}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,20">
                                <TextBlock Text="立刻签到:" VerticalAlignment="Center" Width="100"/>
                                <Button Content="执行" Command="{Binding ExecuteCheckinCommand}" IsEnabled="{Binding IsExecuteEnabled}" Padding="28,6" Margin="0,0,36,0"/>
                                <TextBlock Text="开始时间" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox Width="120"
                                          ItemsSource="{Binding CheckinTimeOptions}"
                                          SelectedItem="{Binding CheckinStartTime}"
                                          IsEnabled="{Binding IsScheduleEnabled}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Margin="0,0,0,10">
                                <TextBlock Text="{Binding CheckinStatusMessage}" Foreground="#FFB45309" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding NextCheckinAtText, StringFormat=下次计划时间：{0}}" Foreground="#FF2563EB" Margin="0,4,0,0"/>
                            </StackPanel>

                            <TextBox Grid.Row="4"
                                     Text="{Binding CheckinLogText}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     BorderBrush="#FFE5E7EB"
                                     BorderThickness="1"
                                     Padding="8"
                                     MinHeight="240"/>

                            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                <!--Button Content="签到设置" Command="{Binding OpenDailyCheckSettingsCommand}" Padding="12,6" Margin="0,0,8,0"/-->
                                <Button Content="保存" Command="{Binding SaveDailyCheckSettingsCommand}" Padding="12,6"/>
                            </StackPanel>
                        </Grid>

                        <Grid Visibility="{Binding IsSettingsPage, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            
                            <TextBlock Grid.Row="1" Text="设置路径" Foreground="Gray" FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <Grid Grid.Row="2" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="86"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="商家路径:" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding MerchantPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" Padding="6,4"/>
                                <Button Grid.Column="2" Content="浏览..." Command="{Binding BrowseMerchantPathCommand}" Padding="10,4"/>
                            </Grid>

                            <Grid Grid.Row="3" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="86"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="辅助路径:" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding HelperPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" Padding="6,4"/>
                                <Button Grid.Column="2" Content="浏览..." Command="{Binding BrowseHelperPathCommand}" Padding="10,4"/>
                            </Grid>

                            <TextBlock Grid.Row="4" Text="提现信息" Foreground="Gray" FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <Grid Grid.Row="5" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="320"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="姓名:" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding WithdrawName, UpdateSourceTrigger=PropertyChanged}" Padding="6,4"/>
                            </Grid>

                            <Grid Grid.Row="6" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="320"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="支付宝:" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding AlipayAccount, UpdateSourceTrigger=PropertyChanged}" Padding="6,4"/>
                            </Grid>

                            <StackPanel Grid.Row="7" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="打款方式:" Width="100" VerticalAlignment="Center"/>
                                    <RadioButton Content="1级或2级代理代付" IsChecked="{Binding IsAgentPayMode}" GroupName="PayMode" Margin="0,0,18,0" VerticalAlignment="Center"/>
                                    <RadioButton Content="区域总代理" IsChecked="{Binding IsRegionalAgentMode}" GroupName="PayMode" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="手续费扣除:" Width="100" VerticalAlignment="Center"/>
                                    <RadioButton Content="从积分扣5%" IsChecked="{Binding IsFeeFromPoints}" GroupName="FeeMode" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="8" Orientation="Vertical">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                    <!--Button Content="捕捉设置" Command="{Binding OpenCaptureSettingsCommand}" Padding="12,6" Margin="0,0,8,0"/-->
                                    <Button Content="保存" Command="{Binding SaveSettingsCommand}" Padding="12,6"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SettingsSaveStatus}" Foreground="#FF2563EB" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
