<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 基底色 -->
    <Color x:Key="ColorAppBackground">#FF0B0F14</Color>
    <Color x:Key="ColorSurfaceMain">#FF121826</Color>
    <Color x:Key="ColorSurfaceCard">#FF171F2E</Color>
    <Color x:Key="ColorSurfaceElevated">#FF1A2233</Color>
    <Color x:Key="ColorNavButton">#FF141A26</Color>
    <Color x:Key="ColorBorderWeak">#FF2A3344</Color>
    <Color x:Key="ColorBorderMid">#FF3A465C</Color>
    <Color x:Key="ColorTextPrimary">#FFE7ECF3</Color>
    <Color x:Key="ColorTextSecondary">#FFA7B0C0</Color>
    <Color x:Key="ColorInputBackground">#FF0F1420</Color>
    <Color x:Key="ColorAccentBlue">#FF2F6BFF</Color>
    <Color x:Key="ColorAccentBlueHover">#FF4A7DFF</Color>
    <Color x:Key="ColorAccentBluePressed">#FF2557D6</Color>
    <Color x:Key="ColorAccentYellow">#FFF5C84A</Color>
    <Color x:Key="ColorDanger">#FFE5484D</Color>
    <Color x:Key="ColorDangerHover">#FFF25F64</Color>
    <Color x:Key="ColorDangerPressed">#FFC73E42</Color>
    <Color x:Key="ColorSecondaryHover">#FF1C2638</Color>
    <Color x:Key="ColorSecondaryPressed">#FF141A22</Color>
    <Color x:Key="ColorHeaderBar">#FF0E1219</Color>
    <Color x:Key="ColorSidebar">#FF0E1219</Color>
    <Color x:Key="ColorGridHeader">#FF2F6BFF</Color>
    <Color x:Key="ColorSuccess">#FF34D399</Color>
    <Color x:Key="ColorFail">#FFF87171</Color>
    <Color x:Key="ColorInfo">#FF60A5FA</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource ColorAppBackground}"/>
    <SolidColorBrush x:Key="SurfaceMainBrush" Color="{StaticResource ColorSurfaceMain}"/>
    <SolidColorBrush x:Key="SurfaceCardBrush" Color="{StaticResource ColorSurfaceCard}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource ColorSurfaceElevated}"/>
    <SolidColorBrush x:Key="NavButtonBackgroundBrush" Color="{StaticResource ColorNavButton}"/>
    <SolidColorBrush x:Key="BorderWeakBrush" Color="{StaticResource ColorBorderWeak}"/>
    <SolidColorBrush x:Key="BorderMidBrush" Color="{StaticResource ColorBorderMid}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource ColorInputBackground}"/>
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource ColorAccentBlue}"/>
    <SolidColorBrush x:Key="AccentBlueHoverBrush" Color="{StaticResource ColorAccentBlueHover}"/>
    <SolidColorBrush x:Key="AccentBluePressedBrush" Color="{StaticResource ColorAccentBluePressed}"/>
    <SolidColorBrush x:Key="AccentYellowBrush" Color="{StaticResource ColorAccentYellow}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource ColorDanger}"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource ColorDangerHover}"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="{StaticResource ColorDangerPressed}"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="{StaticResource ColorSecondaryHover}"/>
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="{StaticResource ColorSecondaryPressed}"/>
    <SolidColorBrush x:Key="HeaderBarBrush" Color="{StaticResource ColorHeaderBar}"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource ColorSidebar}"/>
    <SolidColorBrush x:Key="GridHeaderBrush" Color="{StaticResource ColorGridHeader}"/>
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{StaticResource ColorSuccess}"/>
    <SolidColorBrush x:Key="FailTextBrush" Color="{StaticResource ColorFail}"/>
    <SolidColorBrush x:Key="InfoTextBrush" Color="{StaticResource ColorInfo}"/>
    <SolidColorBrush x:Key="HeaderPrimaryTextBrush" Color="#FFFFFFFF"/>

    <!-- 下拉 Popup 等仍引用系统窗口色（与 MainWindow 子树一致） -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF121826"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FFE7ECF3"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF2F6BFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF171F2E"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FFE7ECF3"/>

    <!-- 圆角按钮模板 -->
    <Style x:Key="AppSecondaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="{StaticResource SurfaceElevatedBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderMidBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SecondaryHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SecondaryPressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppPrimaryButton" TargetType="Button" BasedOn="{StaticResource AppSecondaryButton}">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlueHoverBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBlueHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBluePressedBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBluePressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppDangerButton" TargetType="Button" BasedOn="{StaticResource AppSecondaryButton}">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerHoverBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource DangerHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerPressedBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource DangerPressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="Background" Value="{StaticResource NavButtonBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceElevatedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SecondaryPressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Value="True">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource NavPageSelectedConverter}">
                        <Binding Path="CurrentPage"/>
                        <Binding Path="Tag" RelativeSource="{RelativeSource Self}"/>
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Background" Value="{StaticResource SurfaceElevatedBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                <Setter Property="BorderThickness" Value="3,0,0,0"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AppTextBoxStyle" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderWeakBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AccentBlueBrush}"/>
    </Style>

    <!-- 只读日志弹窗 -->
    <Style x:Key="AppLogTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource AppTextBoxStyle}">
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="AcceptsReturn" Value="True"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="AppPasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderWeakBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AccentBlueBrush}"/>
    </Style>

    <!-- 非可编辑：自定义模板，避免系统 ToggleButton 浅底 + 选中项浅色字导致折叠态看不清 -->
    <Style x:Key="AppComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderWeakBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="IsEditable" Value="False"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid x:Name="dropDownRoot" SnapsToDevicePixels="True">
                        <ToggleButton x:Name="toggleButton"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      Focusable="False"
                                      ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="tbRoot"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4"
                                            SnapsToDevicePixels="True">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="26"/>
                                            </Grid.ColumnDefinitions>
                                            <Path Grid.Column="1"
                                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                                  Fill="{StaticResource TextSecondaryBrush}"
                                                  Stretch="Uniform"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,0"
                                                  Width="8"
                                                  Height="5"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="tbRoot" Property="Background" Value="{StaticResource SecondaryHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="tbRoot" Property="Background" Value="{StaticResource SecondaryPressedBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="contentPresenter"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          IsHitTestVisible="False"
                                          Focusable="False"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="False"
                               Focusable="False"
                               Placement="Bottom"
                               PopupAnimation="None"
                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <Border Background="{StaticResource InputBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderWeakBrush}"
                                    BorderThickness="1"
                                    Margin="0,2,0,0"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    MinWidth="{Binding ActualWidth, ElementName=dropDownRoot}">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto"
                                              CanContentScroll="True"
                                              SnapsToDevicePixels="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="dropDownRoot" Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 默认模板里 ContentPresenter 不总继承 Foreground；显式绑定避免下拉项仍是系统深色字 -->
    <Style x:Key="AppComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- 键盘/鼠标在下拉中的高亮 -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceElevatedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SecondaryHoverBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppRadioButtonStyle" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="AppDataGridStyle" TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource SurfaceMainBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderWeakBrush}"/>
        <Setter Property="RowBackground" Value="{StaticResource SurfaceMainBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource SurfaceCardBrush}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderWeakBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderWeakBrush}"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
    </Style>

    <Style x:Key="AppDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource GridHeaderBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBluePressedBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
    </Style>

    <Style x:Key="AppDataGridCellStyle" TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,2"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource SecondaryHoverBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 隐式样式必须放在主题字典内；Style.BasedOn 仅支持 StaticResource，否则 XamlParseException -->
    <Style TargetType="TextBox" BasedOn="{StaticResource AppTextBoxStyle}"/>
    <Style TargetType="PasswordBox" BasedOn="{StaticResource AppPasswordBoxStyle}"/>
    <Style TargetType="RadioButton" BasedOn="{StaticResource AppRadioButtonStyle}"/>
    <Style TargetType="ComboBox" BasedOn="{StaticResource AppComboBoxStyle}">
        <Setter Property="ItemContainerStyle" Value="{StaticResource AppComboBoxItemStyle}"/>
    </Style>
    <Style TargetType="DataGrid" BasedOn="{StaticResource AppDataGridStyle}"/>
    <Style TargetType="DataGridCell" BasedOn="{StaticResource AppDataGridCellStyle}"/>
</ResourceDictionary>
