<Window x:Class="IpspoolAutomation.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="注册 -智灵科技" Height="360" Width="380"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="24"
          Background="{DynamicResource AppBackgroundBrush}"
          TextElement.Foreground="{DynamicResource TextPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="用户名"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <TextBox Grid.Row="1"
                 Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,12"
                 Padding="8,6"/>
        <TextBlock Grid.Row="2"
                   Text="密码"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <PasswordBox x:Name="PasswordBox"
                     Grid.Row="3"
                     Margin="0,0,0,8"
                     Padding="8,6"/>
        <TextBlock Grid.Row="4"
                   Text="确认密码"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <PasswordBox x:Name="ConfirmPasswordBox"
                     Grid.Row="5"
                     Margin="0,0,0,8"
                     Padding="8,6"/>
        <StackPanel Grid.Row="6" Orientation="Vertical">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource FailTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4"/>
            <TextBlock Text="{Binding SuccessMessage}"
                       Foreground="{DynamicResource SuccessTextBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>
        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="BackButton"
                    Content="返回登录"
                    Click="BackButton_Click"
                    Style="{DynamicResource AppSecondaryButton}"
                    Margin="0,0,8,0"/>
            <Button x:Name="RegisterButton"
                    Content="注册"
                    Click="RegisterButton_Click"
                    Style="{DynamicResource AppPrimaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
