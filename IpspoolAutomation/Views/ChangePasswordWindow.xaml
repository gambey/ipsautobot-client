<Window x:Class="IpspoolAutomation.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="修改密码" Height="420" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="24"
          Background="{DynamicResource AppBackgroundBrush}"
          TextElement.Foreground="{DynamicResource TextPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="账号/手机号"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <TextBox Grid.Row="1"
                 Text="{Binding Account, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,12"
                 Padding="8,6"/>

        <TextBlock Grid.Row="2"
                   Text="当前密码"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <PasswordBox x:Name="CurrentPasswordBox"
                     Grid.Row="3"
                     Margin="0,0,0,12"
                     Padding="8,6"/>

        <TextBlock Grid.Row="4"
                   Text="新密码"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <PasswordBox x:Name="NewPasswordBox"
                     Grid.Row="5"
                     Margin="0,0,0,12"
                     Padding="8,6"/>

        <TextBlock Grid.Row="6"
                   Text="确认新密码"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <PasswordBox x:Name="ConfirmPasswordBox"
                     Grid.Row="7"
                     Margin="0,0,0,12"
                     Padding="8,6"/>

        <StackPanel Grid.Row="8"
                    Orientation="Vertical"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource FailTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4"/>
            <TextBlock Text="{Binding SuccessMessage}"
                       Foreground="{DynamicResource SuccessTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"/>
        </StackPanel>
        <StackPanel Grid.Row="9"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="返回"
                    Click="BackButton_Click"
                    Style="{DynamicResource AppSecondaryButton}"
                    Margin="0,0,8,0"/>
            <Button Content="确认修改"
                    Click="ChangeButton_Click"
                    IsDefault="True"
                    Style="{DynamicResource AppPrimaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
