<Window x:Class="IpspoolAutomation.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="修改密码" Height="420" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="账号/手机号" Margin="0,0,0,4"/>
        <TextBox Grid.Row="1" Text="{Binding Account, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" Padding="6,4"/>

        <TextBlock Grid.Row="2" Text="当前密码" Margin="0,0,0,4"/>
        <PasswordBox x:Name="CurrentPasswordBox" Grid.Row="3" Margin="0,0,0,12" Padding="6,4"/>

        <TextBlock Grid.Row="4" Text="新密码" Margin="0,0,0,4"/>
        <PasswordBox x:Name="NewPasswordBox" Grid.Row="5" Margin="0,0,0,12" Padding="6,4"/>

        <TextBlock Grid.Row="6" Text="确认新密码" Margin="0,0,0,4"/>
        <PasswordBox x:Name="ConfirmPasswordBox" Grid.Row="7" Margin="0,0,0,12" Padding="6,4"/>

        <StackPanel Grid.Row="8" Orientation="Vertical" HorizontalAlignment="Stretch">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding SuccessMessage}" Foreground="Green" TextWrapping="Wrap" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="返回" Click="BackButton_Click" Margin="0,0,8,0" Padding="12,6"/>
                <Button Content="确认修改" Click="ChangeButton_Click" Padding="12,6" IsDefault="True"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>

