<Window x:Class="IpspoolAutomation.Views.ExchangeLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="兑换日志" Height="520" Width="760"
        WindowStartupLocation="CenterOwner"
        MinHeight="360" MinWidth="560"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="12" Background="{DynamicResource AppBackgroundBrush}">
        <TextBox x:Name="LogTextBox"
                 Style="{DynamicResource AppLogTextBoxStyle}"
                 Text="{Binding ExchangeLogText, Mode=OneWay}"
                 TextChanged="LogTextBox_OnTextChanged"
                 IsReadOnly="True"/>
    </Grid>
</Window>
