<Window x:Class="IpspoolAutomation.Views.AutoAcceptOrderSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="自动接单设置" Height="720" Width="1520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="1420"
        MinHeight="560">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="轮询间隔（分钟）" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Width="72" Text="{Binding PollIntervalMinutesText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
            <TextBlock Text="最高可接受退款率（0–100）" VerticalAlignment="Center" Margin="24,0,8,0"/>
            <TextBox Width="72" Text="{Binding MaxRefundRatePercentText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="导航步骤（进入订单市场首页前）" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Button Content="新增导航步骤" Command="{Binding AddNavigationTargetCommand}" Padding="12,6" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                <Border BorderBrush="#FFD1D5DB" BorderThickness="1" Padding="8" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="#" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="目标类型" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="目标文字" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="锚点类型" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="锚点文字" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="偏移X" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="偏移Y" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="7" Text="动作" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="8" Text="输入值" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="9" Text="延迟(毫秒)" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="10" Text="备注" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="11" Text="插入" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="12" Text="操作" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding NavigationTargets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding TargetID}" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Column="1"
                                                      SelectedItem="{Binding TargetType, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemsSource="{Binding DataContext.TargetTypeOptions, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            <TextBox Grid.Column="2" Text="{Binding TargetText, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                            <ComboBox Grid.Column="3"
                                                      SelectedItem="{Binding AnchorType, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemsSource="{Binding DataContext.TargetTypeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      Margin="4,0,0,0"/>
                                            <TextBox Grid.Column="4" Text="{Binding AnchorText, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                            <TextBox Grid.Column="5" Text="{Binding OffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                            <TextBox Grid.Column="6" Text="{Binding OffsetY, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                            <ComboBox Grid.Column="7"
                                                      SelectedItem="{Binding Action, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemsSource="{Binding DataContext.ActionOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      Margin="4,0,0,0"/>
                                            <TextBox Grid.Column="8" Text="{Binding InputValue, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                            <TextBox Grid.Column="9" Text="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                            <TextBox Grid.Column="10" Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                            <Button Grid.Column="11" Content="+" Padding="4,2" FontWeight="SemiBold"
                                                    Command="{Binding DataContext.InsertNavigationBelowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Grid.Column="12" Content="删除" Foreground="#FFDC2626"
                                                    Command="{Binding DataContext.DeleteNavigationTargetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <TextBlock Text="翻页步骤（每页采集后执行；留空则点击名称含「下一页」的按钮）" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Border BorderBrush="#FFD1D5DB" BorderThickness="1" Padding="8" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding NextPageRow.TargetID}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  SelectedItem="{Binding NextPageRow.TargetType, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding TargetTypeOptions}"/>
                        <TextBox Grid.Column="2" Text="{Binding NextPageRow.TargetText, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                        <ComboBox Grid.Column="3"
                                  SelectedItem="{Binding NextPageRow.AnchorType, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding TargetTypeOptions}"
                                  Margin="4,0,0,0"/>
                        <TextBox Grid.Column="4" Text="{Binding NextPageRow.AnchorText, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                        <TextBox Grid.Column="5" Text="{Binding NextPageRow.OffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                        <TextBox Grid.Column="6" Text="{Binding NextPageRow.OffsetY, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                        <ComboBox Grid.Column="7"
                                  SelectedItem="{Binding NextPageRow.Action, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding ActionOptions}"
                                  Margin="4,0,0,0"/>
                        <TextBox Grid.Column="8" Text="{Binding NextPageRow.InputValue, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                        <TextBox Grid.Column="9" Text="{Binding NextPageRow.DelayMs, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                        <TextBox Grid.Column="10" Text="{Binding NextPageRow.Remark, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                    </Grid>
                </Border>

                <TextBlock Text="签约步骤（占位符 {pageIndex}、{itemIndex}；页码为 1–9，行序为当前页内序号）" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Button Content="新增签约步骤" Command="{Binding AddSignTargetCommand}" Padding="12,6" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                <Border BorderBrush="#FFD1D5DB" BorderThickness="1" Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="#" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="目标类型" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="目标文字" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="锚点类型" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="锚点文字" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="偏移X" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="偏移Y" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="7" Text="动作" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="8" Text="输入值" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="9" Text="延迟(毫秒)" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="10" Text="备注" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="11" Text="插入" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="12" Text="操作" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SignTargets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding TargetID}" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Column="1"
                                                      SelectedItem="{Binding TargetType, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemsSource="{Binding DataContext.TargetTypeOptions, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            <TextBox Grid.Column="2" Text="{Binding TargetText, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                            <ComboBox Grid.Column="3"
                                                      SelectedItem="{Binding AnchorType, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemsSource="{Binding DataContext.TargetTypeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      Margin="4,0,0,0"/>
                                            <TextBox Grid.Column="4" Text="{Binding AnchorText, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                            <TextBox Grid.Column="5" Text="{Binding OffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                            <TextBox Grid.Column="6" Text="{Binding OffsetY, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                            <ComboBox Grid.Column="7"
                                                      SelectedItem="{Binding Action, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemsSource="{Binding DataContext.ActionOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      Margin="4,0,0,0"/>
                                            <TextBox Grid.Column="8" Text="{Binding InputValue, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                            <TextBox Grid.Column="9" Text="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                            <TextBox Grid.Column="10" Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                            <Button Grid.Column="11" Content="+" Padding="4,2" FontWeight="SemiBold"
                                                    Command="{Binding DataContext.InsertSignBelowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Grid.Column="12" Content="删除" Foreground="#FFDC2626"
                                                    Command="{Binding DataContext.DeleteSignTargetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="确定" Command="{Binding ConfirmCommand}" Padding="28,6"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="0,6,0,0" Foreground="#FF2563EB" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>
