<Window x:Class="IpspoolAutomation.Views.SubscribeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="订阅 - 支付宝扫码支付" Height="380" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="订阅软件服务 - 支付宝扫码支付" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
        <Button Grid.Row="1" Content="生成支付宝付款码" Command="{Binding CreateOrderCommand}" Padding="12,8" Margin="0,0,0,12"
                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"/>
        <StackPanel Grid.Row="2" Visibility="{Binding ShowQrCode, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="请使用支付宝扫描下方二维码完成支付" Margin="0,0,0,8"/>
            <Image x:Name="QrImage" MaxHeight="220" MaxWidth="220" HorizontalAlignment="Left"/>
        </StackPanel>
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,12,0,0" Foreground="DarkGreen"/>
        <Button Grid.Row="4" Content="关闭" Click="CloseButton_Click" Padding="12,6" HorizontalAlignment="Right" Margin="0,16,0,0"/>
    </Grid>
</Window>
